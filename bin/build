#!/bin/bash

# Default to both platforms if no argument provided
# Pass "amd64" or "arm64" to build just one platform
PLATFORMS=${1:-"linux/amd64,linux/arm64"}

if [ "$1" = "amd64" ]; then
  PLATFORMS="linux/amd64"
elif [ "$1" = "arm64" ]; then
  PLATFORMS="linux/arm64"
fi

AMD_host="dkam@100.90.210.72"

echo "Building for platforms: $PLATFORMS"
echo "Using multi-platform build with remote builders"
echo "AMD host: $AMD_host"

# Setup multi-builder if it doesn't exist
if ! docker buildx ls | grep -q "multi-builder"; then
  echo "Creating multi-builder with remote AMD host..."
  docker buildx create --name multi-builder \
    --driver docker-container \
    --platform linux/arm64 \
    --use
  docker buildx create --name multi-builder --append \
    --driver docker-container \
    --platform linux/amd64 \
    ssh://$AMD_host
fi

# Update VERSION file with current version
echo "Updating VERSION file..."
VERSION=$(git describe --tags --always --dirty 2>/dev/null || echo "$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')")
echo "$VERSION" > VERSION
echo "VERSION updated to: $(cat VERSION)"

# Derive flavor from current git branch. feature/pg ships the Postgres
# build; main ships the SQLite build. Refuse to build from any other
# branch so we never push an ambiguously-tagged image.
BRANCH=$(git rev-parse --abbrev-ref HEAD)
case "$BRANCH" in
  feature/pg) FLAVOR="pg" ;;
  main)       FLAVOR="sqlite" ;;
  *)
    echo "ERROR: unknown branch '$BRANCH'. bin/build only knows feature/pg (pg) and main (sqlite)."
    exit 1
    ;;
esac

SHA=$(git rev-parse HEAD)
echo "Flavor: $FLAVOR (branch $BRANCH)"
echo "Tags:   reg.tbdb.info/splat:${FLAVOR}-latest"
echo "        reg.tbdb.info/splat:${FLAVOR}-${SHA}"
echo "        reg.tbdb.info/splat:${SHA}"

# Use the multi-builder
docker buildx use multi-builder

docker buildx build \
  --platform "$PLATFORMS" \
  -t reg.tbdb.info/splat:${FLAVOR}-latest \
  -t reg.tbdb.info/splat:${FLAVOR}-${SHA} \
  -t reg.tbdb.info/splat:${SHA} \
  --push .
