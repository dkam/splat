#!/bin/bash

# Default to both platforms if no argument provided
# Pass "amd64" or "arm64" to build just one platform
PLATFORMS=${1:-"linux/amd64,linux/arm64"}

if [ "$1" = "amd64" ]; then
  PLATFORMS="linux/amd64"
elif [ "$1" = "arm64" ]; then
  PLATFORMS="linux/arm64"
fi

AMD_host="dkam@100.90.210.72"

echo "Building for platforms: $PLATFORMS"
echo "Using multi-platform build with remote builders"
echo "AMD host: $AMD_host"

# Setup multi-builder if it doesn't exist
if ! docker buildx ls | grep -q "multi-builder"; then
  echo "Creating multi-builder with remote AMD host..."
  docker buildx create --name multi-builder \
    --driver docker-container \
    --platform linux/arm64 \
    --use
  docker buildx create --name multi-builder --append \
    --driver docker-container \
    --platform linux/amd64 \
    ssh://$AMD_host
fi

# Version = build timestamp + short commit, e.g. "20260621-143022-g389c428".
# No tags required — every build is uniquely identified, and Splat::VERSION
# (which reads this file) shows when the running image was built. VERSION is
# gitignored: it's a build artifact, regenerated here and in CI.
if [ -n "$(git status --porcelain)" ]; then
  echo "WARNING: building from a dirty working tree — the image won't be reproducible from a commit."
fi
VERSION="$(date -u +%Y%m%d-%H%M%S)-g$(git rev-parse --short HEAD)"
echo "$VERSION" > VERSION
echo "VERSION: $VERSION"

# SQLite is the only flavour now, so we build from main only. Refuse any
# other branch so we never push an ambiguously-tagged image.
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
  echo "ERROR: bin/build only builds from main (got '$BRANCH')."
  exit 1
fi

SHA=$(git rev-parse HEAD)
echo "Tags:   reg.tbdb.info/splat:latest"
echo "        reg.tbdb.info/splat:${VERSION}"
echo "        reg.tbdb.info/splat:${SHA}"

# Use the multi-builder
docker buildx use multi-builder

docker buildx build \
  --platform "$PLATFORMS" \
  -t reg.tbdb.info/splat:latest \
  -t "reg.tbdb.info/splat:${VERSION}" \
  -t reg.tbdb.info/splat:${SHA} \
  --push .
