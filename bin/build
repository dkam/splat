#!/bin/bash

# Default to both platforms if no argument provided
# Pass "amd64" or "arm64" to build just one platform
PLATFORMS=${1:-"linux/amd64,linux/arm64"}

if [ "$1" = "amd64" ]; then
  PLATFORMS="linux/amd64"
elif [ "$1" = "arm64" ]; then
  PLATFORMS="linux/arm64"
fi

AMD_host="dkam@100.90.210.72"

echo "Building for platforms: $PLATFORMS"
echo "Using multi-platform build with remote builders"
echo "AMD host: $AMD_host"

# Setup multi-builder if it doesn't exist
if ! docker buildx ls | grep -q "multi-builder"; then
  echo "Creating multi-builder with remote AMD host..."
  docker buildx create --name multi-builder \
    --driver docker-container \
    --platform linux/arm64 \
    --use
  docker buildx create --name multi-builder --append \
    --driver docker-container \
    --platform linux/amd64 \
    ssh://$AMD_host
fi

# Version is the hand-set SemVer constant in config/version.rb. Read it without
# booting Rails so we can tag the image :vX.Y.Z.
VERSION=$(ruby -e "require './config/version'; puts Splat::VERSION")
echo "Building v${VERSION}"

# Branch policy depends on the version. A pre-release (X.Y.Z-dev) only ever
# publishes :vX.Y.Z-dev and never moves :latest (see TAGS below), so it's safe
# to build from any branch for testing. A real release moves :latest, so it
# must come from main to avoid an ambiguously-tagged image.
BRANCH=$(git rev-parse --abbrev-ref HEAD)
case "$VERSION" in
  *-*)
    [ "$BRANCH" != "main" ] && echo "Pre-release build from branch '$BRANCH' — publishes :v${VERSION} only, never :latest"
    ;;
  *)
    if [ "$BRANCH" != "main" ]; then
      echo "ERROR: release builds only from main (got '$BRANCH'). Use a pre-release version (e.g. ${VERSION}-dev) to build from a branch."
      exit 1
    fi
    ;;
esac

# Always publish :vX.Y.Z; only move :latest for a non-pre-release version.
TAGS=(-t "reg.tbdb.info/splat:v${VERSION}")
case "$VERSION" in
  *-*) echo "Pre-release ${VERSION} — publishing :v${VERSION} only (not :latest)" ;;
  *)   TAGS+=(-t reg.tbdb.info/splat:latest); echo "Release ${VERSION} — publishing :v${VERSION} + :latest" ;;
esac

# Use the multi-builder
docker buildx use multi-builder

docker buildx build \
  --platform "$PLATFORMS" \
  "${TAGS[@]}" \
  --push .
