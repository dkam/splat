#!/usr/bin/env ruby
# frozen_string_literal: true

# Force unbuffered stdout — without this, Ruby fully-buffers when stdout is a
# pipe (e.g. docker log capture) and Rails.logger.info messages sit in the
# buffer until 4KB accumulates or the process exits. Long-running idle
# workers appear silent for hours otherwise.
STDOUT.sync = true
STDERR.sync = true

require_relative "../config/environment"

# Role selects which tube consumers this process runs (see Ingest::Worker):
# "ingest" (default) = the real-time data tubes; "maintenance" = splat.maintenance.
role = ARGV[0] || ENV["WORKER_ROLE"] || "ingest"
consumers = Ingest::Worker.consumers_for(role)

shutdown = lambda do |signal|
  # STDERR.puts (not Rails.logger) — Logger uses a mutex which can't be
  # acquired from a Ruby signal-trap context.
  STDERR.puts "[Worker:#{role}] received #{signal}, draining and exiting"
  consumers.each(&:stop!)
end

trap("INT")  { shutdown.call("SIGINT") }
trap("TERM") { shutdown.call("SIGTERM") }

Rails.logger.info "[Worker:#{role}] starting #{consumers.size} consumer(s)"
threads = consumers.map { |c| Thread.new { c.run } }
threads.each(&:join)
