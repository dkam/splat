<%= turbo_refreshes_with method: :morph, scroll: :preserve %>
<%= turbo_stream_from @issue %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="mb-8">
    <%= link_to "← Issues", project_issues_path(@project.slug), class: "text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100" %>
  </div>

  <!-- Issue Header -->
  <div class="mb-8">
    <div class="flex items-start justify-between gap-4 mb-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl font-mono text-gray-500 dark:text-gray-400 font-medium">#<%= @issue.id %></span>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @issue.title %></h1>
        </div>
        <p class="text-gray-600 dark:text-gray-400">
          <span class="font-mono text-sm bg-gray-100 dark:bg-gray-800 dark:text-gray-200 px-2 py-1 rounded"><%= @issue.exception_type %></span>
        </p>
      </div>

      <!-- Status + Actions -->
      <div class="flex items-center gap-2 shrink-0">
        <div id="issue-status">
          <% if @issue.resolved? %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-green-700 dark:text-green-300 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-md">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Resolved
            </span>
          <% elsif @issue.ignored? %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zM17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/></svg>
              Ignored
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-red-700 dark:text-red-300 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-md">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              Open
            </span>
          <% end %>
        </div>

        <!-- Action Buttons -->
        <div id="issue-actions" class="flex gap-2">
        <% if @issue.resolved? %>
          <%= button_to reopen_project_issue_path(@project.slug, @issue),
              method: :patch,
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-md hover:bg-blue-100 dark:hover:bg-blue-900/50 hover:border-blue-300 dark:hover:border-blue-700 transition-colors",
              form: { data: { turbo: true } } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Reopen
          <% end %>
        <% else %>
          <%= button_to resolve_project_issue_path(@project.slug, @issue),
              method: :patch,
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-green-700 dark:text-green-300 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-md hover:bg-green-100 dark:hover:bg-green-900/50 hover:border-green-300 dark:hover:border-green-700 transition-colors",
              form: { data: { turbo: true } } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Resolve
          <% end %>
          <%= button_to ignore_project_issue_path(@project.slug, @issue),
              method: :patch,
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-colors",
              form: { data: { turbo: true } } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zM17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/></svg>
            Ignore
          <% end %>
        <% end %>
        </div>
      </div>
    </div>
    <%= turbo_stream_from @issue, "updates" %>
    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
        <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">Total Events</div>
        <div id="issue-count" class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @issue.count %></div>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
        <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">First Seen</div>
        <div class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= @issue.first_seen.strftime("%Y-%m-%d %H:%M:%S") %></div>
      </div>
      <div id="last-seen" class="bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
        <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">Last Seen</div>
        <div class="text-lg font-semibold text-gray-900 dark:text-gray-100">
          <%= time_ago_in_words(@issue.last_seen) %> ago
          <div class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= @issue.last_seen.strftime("%Y-%m-%d %H:%M:%S") %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 7-day event volume -->
  <% if @issue.bursting? %>
    <div class="mb-8 bg-orange-50 dark:bg-orange-900/30 border border-orange-200 dark:border-orange-800 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <span class="text-2xl">🔥</span>
        <div class="flex-1 text-sm text-orange-900 dark:text-orange-200">
          <p class="font-semibold mb-1">Bursting</p>
          <p>
            This issue was emitting
            <strong><%= number_with_delimiter(@issue.last_burst_rate) %> events/hour</strong>
            (threshold: <%= number_with_delimiter(Setting.instance.burst_threshold) %>/hour) at
            <strong><%= @issue.last_burst_at.strftime("%Y-%m-%d %H:%M:%S") %></strong>.
            Splat sent a spike alert; the issue is still being tracked.
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <% if @spark_counts.any? { |v| v.to_i.positive? } %>
    <div class="mb-8 bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
      <div class="flex justify-between items-baseline mb-3">
        <h2 class="text-sm font-medium text-gray-600 dark:text-gray-400">Events · last 7 days</h2>
        <span class="text-xs text-gray-500 dark:text-gray-400">peak <%= number_with_delimiter(@spark_counts.max) %> / hr</span>
      </div>
      <div class="text-blue-500 dark:text-blue-400 [&_svg]:w-full [&_svg]:h-20" title="Events per hour, last 7 days. Dashed lines = deploys.">
        <%= sparkline(@spark_counts, width: 600, height: 80,
            title: "#{number_with_delimiter(@spark_counts.sum)} events in last 7 days — peak #{number_with_delimiter(@spark_counts.max)} / hr",
            markers: @deploy_markers, time_range: @spark_range) %>
      </div>
    </div>
  <% end %>

  <!-- Releases -->
  <% if @issue.first_seen_release.present? || @issue.last_seen_release.present? %>
    <% regression = @issue.first_seen_release.present? &&
                    @issue.last_seen_release.present? &&
                    @issue.first_seen_release != @issue.last_seen_release %>
    <div class="mb-8 bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Releases</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">First seen in</div>
          <code class="text-sm font-mono text-gray-900 dark:text-gray-100 break-all"><%= @issue.first_seen_release.presence || "—" %></code>
        </div>
        <div>
          <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">Last seen in</div>
          <code class="text-sm font-mono <%= regression ? "text-red-700 dark:text-red-400" : "text-gray-900 dark:text-gray-100" %> break-all">
            <%= @issue.last_seen_release.presence || "—" %>
          </code>
          <% if regression %>
            <span class="ml-2 inline-block px-2 py-0.5 text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300 rounded">Spans multiple releases</span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Fingerprint (for debugging) -->
  <details class="mb-8">
    <summary class="cursor-pointer text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100">Show fingerprint</summary>
    <div class="mt-2 bg-gray-50 dark:bg-gray-800 rounded p-3 border border-gray-200 dark:border-gray-700">
      <code class="text-xs font-mono text-gray-700 dark:text-gray-200"><%= @issue.fingerprint %></code>
    </div>
  </details>

  <!-- Events List -->
  <div>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      Events (<span id="events-count"><%= @events.size %></span>)
    </h2>

    <% if @events.any? %>
      <div id="events-list" class="bg-white dark:bg-gray-900 rounded-lg shadow border border-gray-200 dark:border-gray-800 divide-y divide-gray-200 dark:divide-gray-800">
        <% @events.each do |event| %>
          <%= render 'events/event_row', event: event, project: @project %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-8 text-center border border-gray-200 dark:border-gray-800">
        <p class="text-gray-600 dark:text-gray-400">No events for this issue</p>
      </div>
    <% end %>
  </div>
</div>


