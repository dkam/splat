<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Projects</h1>
    <%= link_to "New Project", new_project_path, class: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg" %>
  </div>

  <% if @projects.any? %>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% @projects.each do |project| %>
        <%= link_to project_path(project.slug), class: "block" do %>
          <div class="bg-white dark:bg-gray-900 rounded-lg shadow hover:shadow-lg transition-shadow p-6 border border-gray-200 dark:border-gray-800">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-2"><%= project.name %></h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">/<%= project.slug %></p>

            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">Open Issues:</span>
                <span class="font-medium text-red-600 dark:text-red-400"><%= @open_issue_counts[project.id] || 0 %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">Last Error:</span>
                <span class="font-medium text-gray-900 dark:text-gray-100">
                  <% if (last_at = @last_error_at[project.id]) %>
                    <%= time_ago_in_words(last_at) %> ago
                  <% else %>
                    Never
                  <% end %>
                </span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600 dark:text-gray-400">Last Transaction:</span>
                <span class="font-medium text-gray-900 dark:text-gray-100">
                  <% if (last_at = @last_transaction_at[project.id]) %>
                    <%= time_ago_in_words(last_at) %> ago
                  <% else %>
                    Never
                  <% end %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">No projects yet</h3>
      <p class="text-gray-600 dark:text-gray-400 mb-4">Create your first project to start tracking errors</p>
      <%= link_to "Create Project", new_project_path, class: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg inline-block" %>
    </div>
  <% end %>
</div>
