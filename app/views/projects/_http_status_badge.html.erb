<%# locals: (status:, size: "px-2 py-1 text-xs") -%>
<% if status.present? %>
  <span class="<%= size %> font-medium rounded <%= status.to_i >= 500 ? 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300' : status.to_i >= 400 ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300' : 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' %>">
    <%= status %>
  </span>
<% else %>
  <span class="text-gray-400 dark:text-gray-500 text-sm">-</span>
<% end %>
