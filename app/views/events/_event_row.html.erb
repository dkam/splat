<%= link_to project_event_path(project.slug, event), class: "block hover:bg-gray-50 dark:hover:bg-gray-800/60 p-4 transition-colors", id: "event-#{event.id}" do %>
  <div class="flex justify-between items-start gap-4">
    <div class="flex-1 min-w-0">
      <div class="font-medium text-gray-900 dark:text-gray-100 mb-2 break-words">
        <%= event.message || event.exception_value %>
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-600 dark:text-gray-400 min-w-0">
        <span class="font-mono text-xs bg-gray-100 dark:bg-gray-800 dark:text-gray-200 px-2 py-1 rounded shrink-0">
          <%= event.event_id %>
        </span>
        <% if event.environment.present? %>
          <span class="px-2 py-1 text-xs bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300 rounded shrink-0">
            <%= event.environment %>
          </span>
        <% end %>
        <% if event.release.present? %>
          <span class="font-mono text-xs text-gray-500 dark:text-gray-400 truncate max-w-[16rem]" title="<%= event.release %>"><%= event.release %></span>
        <% end %>
        <% if event.server_name.present? %>
          <span class="font-mono text-xs text-gray-500 dark:text-gray-400 shrink-0" title="<%= event.server_name %>"><%= event.server_name %></span>
        <% end %>
      </div>
    </div>
    <div class="text-right text-sm text-gray-500 dark:text-gray-400 shrink-0 whitespace-nowrap">
      <%= event.timestamp.strftime("%Y-%m-%d") %>
      <div class="text-xs"><%= event.timestamp.strftime("%H:%M:%S") %></div>
    </div>
  </div>
<% end %>
