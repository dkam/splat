<!-- Header Toolbar -->
<header class="fixed top-0 left-0 right-0 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 shadow-sm z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo/Branding -->
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center space-x-2 text-gray-900 dark:text-gray-100 hover:text-gray-700 dark:hover:text-white transition-colors" do %>
          <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">Splat!</div>
        <% end %>
      </div>

      <!-- Project context: Overview / Errors / Performance -->
      <% if @project&.persisted? %>
        <%= render "shared/project_nav", project: @project %>
      <% end %>

      <!-- Right side: System Status & Authentication -->
      <div class="flex items-center space-x-6">
        <!-- Theme Toggle -->
        <div data-controller="theme">
          <button type="button"
                  data-action="theme#toggle"
                  data-theme-target="sun"
                  class="inline-flex items-center justify-center w-8 h-8 rounded-md border border-gray-300 dark:border-gray-700 text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-900 transition-colors"
                  title="Switch to dark mode"
                  aria-label="Switch to dark mode">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </button>
          <button type="button"
                  data-action="theme#toggle"
                  data-theme-target="moon"
                  class="hidden inline-flex items-center justify-center w-8 h-8 rounded-md border border-gray-300 dark:border-gray-700 text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-900 transition-colors"
                  title="Switch to light mode"
                  aria-label="Switch to light mode">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
        </div>

        <!-- Storage Link -->
        <%= link_to storage_path,
            class: "inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-700 text-xs font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-900 transition-colors",
            title: "Postgres + DuckLake storage sizes" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <ellipse cx="12" cy="5" rx="8" ry="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></ellipse>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5v6c0 1.657 3.582 3 8 3s8-1.343 8-3V5"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 11v6c0 1.657 3.582 3 8 3s8-1.343 8-3v-6"></path>
          </svg>
          Storage
        <% end %>
        <!-- Settings Link -->
        <%= link_to settings_path,
            class: "inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-700 text-xs font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-900 transition-colors",
            title: "Data Retention Settings" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          Settings
        <% end %>
        <!-- Queue Depth Indicator -->
        <div class="flex items-center space-x-2">
          <span class="text-sm text-gray-600 dark:text-gray-400">Queue Depth:</span>
          <% queue_depth_value = queue_depth %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= queue_depth_value == 0 ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' :
                    queue_depth_value < 10 ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300' :
                    'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300' %>">
            <%= queue_depth_value %>
          </span>
        </div>

        <!-- Authentication Section -->
        <div class="flex items-center space-x-4">
          <% if authenticated? %>
            <!-- User Info -->
            <div class="flex items-center space-x-3">
              <div class="text-right">
                <div class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= current_user_name %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400">
                  <%= current_user_provider %>
                  <% if current_user_authenticated_at %>
                    • <%= time_ago_in_words(current_user_authenticated_at) %> ago
                  <% end %>
                </div>
              </div>

              <!-- Logout Button -->
              <%= button_to logout_path, method: :delete, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-white bg-red-600 hover:bg-red-700 dark:bg-red-700 dark:hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:focus:ring-offset-gray-900 transition-colors", data: { turbo: false }, form: { class: "inline" } do %>
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                Logout
              <% end %>
            </div>
          <% else %>
            <!-- Login Options -->
            <div class="flex items-center space-x-2">
              <% if SplatAuthorization.oidc_configured? %>
                <!-- OIDC Login -->
                <%= link_to login_path,
                    class: "inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-700 text-xs font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-900 transition-colors",
                    title: "Login with OpenID Connect" do %>
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  Login
                <% end %>
              <% end %>

              </div>

            <!-- Configuration Status -->
            <% if !SplatAuthorization.oidc_configured? %>
              <div class="text-xs text-red-600 dark:text-red-400 italic">
                OIDC not configured
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</header>
