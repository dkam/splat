<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <%= link_to "← Performance", project_endpoints_path(@project.slug), class: "text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100" %>
  </div>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2"><%= @endpoint %></h1>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800" title="Median request duration — half of all requests are faster than this, half slower.">
      <div class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-1">P50 Duration</div>
      <div class="text-3xl font-bold <%= duration_color_class(@p50_duration) %>">
        <%= format_duration(@p50_duration) %>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-1">P95 Duration</div>
      <div class="text-3xl font-bold <%= duration_color_class(@p95_duration) %>">
        <%= format_duration(@p95_duration) %>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm font-medium text-gray-600 dark:text-gray-400 mb-1">P99 Duration</div>
      <div class="text-3xl font-bold <%= duration_color_class(@p99_duration) %>">
        <%= format_duration(@p99_duration) %>
      </div>
    </div>
  </div>

  <!-- P95 Latency Trend -->
  <% if @p95_sparkline.any? { |v| v.to_i > 0 } %>
    <div class="mb-6 bg-white dark:bg-gray-900 rounded-lg shadow p-6 border border-gray-200 dark:border-gray-800">
      <div class="flex items-center justify-between mb-3">
        <div class="text-sm font-medium text-gray-600 dark:text-gray-400">P95 Latency Trend</div>
        <div class="text-xs text-gray-400 dark:text-gray-500"><%= @p95_sparkline.size %> buckets · <%= @time_range %></div>
      </div>
      <div class="text-blue-600 dark:text-blue-400 [&>svg]:w-full [&>svg]:h-16">
        <%= sparkline(@p95_sparkline, width: 600, height: 64, title: "P95 duration per bucket over #{@time_range}") %>
      </div>
    </div>
  <% end %>

  <!-- Filters -->
  <div class="mb-6 bg-white dark:bg-gray-900 rounded-lg shadow p-4 border border-gray-200 dark:border-gray-800">
    <%= form_with url: detail_project_endpoints_path(@project.slug), method: :get, class: "flex flex-wrap gap-4" do |f| %>
      <%= f.hidden_field :endpoint, value: @endpoint %>

      <div class="flex-1 min-w-[150px]">
        <%= f.label :time_range, "Time Range", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.select :time_range,
            options_for_select([["Last Hour", "1h"], ["Last 6 Hours", "6h"], ["Last 24 Hours", "24h"], ["Last 7 Days", "7d"]], @time_range),
            {},
            class: "w-full px-3 py-2 border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="flex items-end">
        <%= f.submit "Filter", class: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg" %>
      </div>
    <% end %>
  </div>

  <!-- Transactions Table -->
  <% if @transactions.any? %>
    <div class="bg-white dark:bg-gray-900 rounded-lg shadow border border-gray-200 dark:border-gray-800 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
        <thead class="bg-gray-50 dark:bg-gray-800/60">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Request</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Method</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Timing</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">When</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800">
          <% @transactions.each do |transaction| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/60">
              <td class="px-4 py-3 whitespace-nowrap">
                <div class="font-mono text-sm text-gray-500 dark:text-gray-400">#<%= transaction.id %></div>
                <% if transaction.environment.present? %>
                  <div class="mt-1">
                    <span class="px-2 py-0.5 text-xs bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300 rounded"><%= transaction.environment %></span>
                  </div>
                <% end %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap">
                <% if transaction.http_method.present? %>
                  <div class="font-mono text-sm text-gray-600 dark:text-gray-400"><%= transaction.http_method %></div>
                <% else %>
                  <div class="text-gray-400 dark:text-gray-500">-</div>
                <% end %>
                <% if transaction.http_status.present? %>
                  <div class="mt-1">
                    <%= render "projects/http_status_badge", status: transaction.http_status, size: "px-2 py-0.5 text-xs" %>
                  </div>
                <% end %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-right">
                <div class="font-semibold <%= duration_color_class(transaction.duration) %>">
                  <%= format_duration(transaction.duration) %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                  <% if transaction.db_time.present? %>
                    <span title="Database time">DB <%= format_duration(transaction.db_time) %></span>
                  <% end %>
                  <% if transaction.view_time.present? %>
                    <span title="View rendering time" class="ml-2">View <%= format_duration(transaction.view_time) %></span>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-sm">
                <div class="text-gray-900 dark:text-gray-100"><%= time_ago_in_words(transaction.timestamp) %> ago</div>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 font-mono"><%= transaction.timestamp.strftime("%H:%M:%S") %></div>
                <div class="text-xs text-gray-400 dark:text-gray-500 font-mono"><%= transaction.timestamp.strftime("%Y-%m-%d") %></div>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-right text-sm">
                <%= link_to "View", project_transaction_path(@project.slug, transaction),
                    class: "inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-700 rounded-md text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white dark:bg-gray-900 rounded-lg shadow p-12 text-center border border-gray-200 dark:border-gray-800">
      <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-2">No transactions found</h3>
      <p class="text-gray-600 dark:text-gray-400">No transaction data available for this endpoint in the selected time range</p>
    </div>
  <% end %>
</div>
