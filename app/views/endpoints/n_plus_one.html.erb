<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to "← Back to Performance", project_endpoints_path(@project.slug, time_range: @time_range), class: "text-blue-600 hover:text-blue-800 text-sm" %>
    <h1 class="text-3xl font-bold text-gray-900 mt-2">Endpoints with N+1 Issues</h1>
    <p class="text-gray-600 mt-2">
      Endpoints where multiple requests showed the same SQL pattern repeated more than 3 times — a classic N+1
      signal. Ranked by how many transactions are affected.
    </p>
  </div>

  <!-- Time range tabs -->
  <div class="mb-6 flex gap-2 flex-wrap">
    <% %w[1h 6h 24h 7d 30d].each do |range| %>
      <%= link_to range, n_plus_one_project_endpoints_path(@project.slug, time_range: range, environment: params[:environment]),
          class: "px-3 py-1 rounded-md text-sm font-medium #{@time_range == range ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% end %>
  </div>

  <% if @endpoints.any? %>
    <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Endpoint</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">N+1</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Avg Queries</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Max Queries</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Latency</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @endpoints.each do |endpoint| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <%= link_to detail_project_endpoints_path(@project.slug, name: endpoint["transaction_name"], time_range: @time_range),
                    class: "text-blue-600 hover:text-blue-800 font-medium" do %>
                  <%= endpoint["transaction_name"] %>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <% n = endpoint["n_plus_one_count"].to_i %>
                <% total = endpoint["total_count"].to_i %>
                <% pct = total > 0 ? (n.to_f / total * 100) : 0 %>
                <% pct_label = pct >= 99.95 ? "100%" : "#{pct.round(1)}%" %>
                <% tooltip = "#{number_with_delimiter(n)} of #{number_with_delimiter(total)} transactions tripped the N+1 detector (#{pct.round(2)}%)" %>
                <% color = pct >= 50 ? "bg-red-100 text-red-800" : pct >= 10 ? "bg-orange-100 text-orange-800" : "bg-gray-100 text-gray-700" %>
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium <%= color %>"
                      title="<%= tooltip %>">
                  ⚠ <%= pct_label %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-gray-700">
                <%= endpoint["avg_queries"].to_f.round(1) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <% max_q = endpoint["max_queries"].to_i %>
                <span class="font-semibold <%= max_q > 50 ? 'text-red-700' : max_q > 20 ? 'text-orange-600' : 'text-gray-700' %>">
                  <%= max_q %>
                </span>
              </td>
              <td class="px-6 py-3 whitespace-nowrap text-right">
                <div class="inline-grid grid-cols-[auto_auto] gap-x-2 gap-y-0 text-sm leading-tight">
                  <span class="text-gray-400 text-right">p50</span>
                  <span class="font-semibold <%= duration_color_class(endpoint["p50_duration"]) %> text-right tabular-nums"><%= format_duration(endpoint["p50_duration"]) %></span>
                  <span class="text-gray-400 text-right">p95</span>
                  <span class="font-semibold <%= duration_color_class(endpoint["p95_duration"]) %> text-right tabular-nums"><%= format_duration(endpoint["p95_duration"]) %></span>
                  <span class="text-gray-400 text-right">p99</span>
                  <span class="font-semibold <%= duration_color_class(endpoint["p99_duration"]) %> text-right tabular-nums"><%= format_duration(endpoint["p99_duration"]) %></span>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow p-8 text-center border border-gray-200">
      <p class="text-gray-600">No N+1 patterns detected in this window.</p>
    </div>
  <% end %>
</div>
