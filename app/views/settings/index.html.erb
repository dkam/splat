<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-3xl text-gray-900 dark:text-gray-100">Settings</h1>
    <%= link_to "← Back to Projects", projects_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm text-gray-500 dark:text-gray-400">SQLite total</div>
      <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= number_to_human_size(@sqlite_total) %></div>
    </div>
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm text-gray-500 dark:text-gray-400">Parquet total</div>
      <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= number_to_human_size(@parquet_lake_total) %></div>
    </div>
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm text-gray-500 dark:text-gray-400">Grand total</div>
      <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100"><%= number_to_human_size(@sqlite_total + @parquet_lake_total) %></div>
    </div>
  </div>

  <details class="bg-white dark:bg-gray-900 shadow rounded-lg border border-gray-200 dark:border-gray-800 mb-4 overflow-hidden group">
    <summary class="px-6 py-4 cursor-pointer flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-800/50 list-none">
      <div>
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">SQLite tables</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Primary <code>splat</code> database. Per-page bytes from the <code>dbstat</code> virtual table.</p>
      </div>
      <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 transition-transform group-open:rotate-90 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </summary>
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800 border-t border-gray-200 dark:border-gray-800">
      <thead class="bg-gray-50 dark:bg-gray-800/50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Table</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Rows</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Table size</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Indexes</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @sqlite_tables.each do |t| %>
          <tr>
            <td class="px-6 py-3 text-sm font-mono text-gray-900 dark:text-gray-100"><%= t[:name] %></td>
            <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_with_delimiter(t[:row_estimate]) %></td>
            <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_to_human_size(t[:table_bytes]) %></td>
            <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_to_human_size(t[:index_bytes]) %></td>
            <td class="px-6 py-3 text-sm text-right font-medium text-gray-900 dark:text-gray-100"><%= number_to_human_size(t[:total_bytes]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </details>

  <details class="bg-white dark:bg-gray-900 shadow rounded-lg border border-gray-200 dark:border-gray-800 mb-8 overflow-hidden group">
    <summary class="px-6 py-4 cursor-pointer flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-800/50 list-none">
      <div>
        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">Parquet files</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Per-table file counts and bytes from the on-disk Parquet tree under <code>storage/parquet_lake/</code>.</p>
      </div>
      <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 transition-transform group-open:rotate-90 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </summary>
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800 border-t border-gray-200 dark:border-gray-800">
      <thead class="bg-gray-50 dark:bg-gray-800/50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Table</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Files</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Largest file</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @parquet_lake_tables.each do |t| %>
          <tr>
            <td class="px-6 py-3 text-sm font-mono text-gray-900 dark:text-gray-100"><%= t[:name] %></td>
            <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_with_delimiter(t[:file_count]) %></td>
            <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_to_human_size(t[:max_file_bytes]) %></td>
            <td class="px-6 py-3 text-sm text-right font-medium text-gray-900 dark:text-gray-100"><%= number_to_human_size(t[:total_bytes]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </details>

  <h2 class="font-bold text-2xl text-gray-900 dark:text-gray-100 mb-4">Data Retention</h2>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900/40 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-300 px-4 py-3 rounded mb-6">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="bg-red-100 dark:bg-red-900/40 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-6">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with(model: @setting, url: settings_path, method: :put, class: "space-y-6") do |form| %>
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Event Data Retention</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">Configure how long to keep error event data and payloads</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :event_payloads_retention_days, "Keep Event Payloads", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :event_payloads_retention_days, min: 1, max: 365, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Full JSON payloads for debugging (recommended: 7 days)</p>
        </div>

        <div>
          <%= form.label :events_data_retention_days, "Keep Event Records", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :events_data_retention_days, min: 1, max: 365, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Basic event data for trend analysis (recommended: 30 days)</p>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Transaction Data Retention</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">Configure how long to keep performance transaction data and measurements</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :transaction_measurements_retention_days, "Keep Transaction Measurements", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :transaction_measurements_retention_days, min: 1, max: 365, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Detailed performance measurements (recommended: 7 days)</p>
        </div>

        <div>
          <%= form.label :transactions_data_retention_days, "Keep Transaction Records", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :transactions_data_retention_days, min: 1, max: 365, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Basic performance data for trends (recommended: 90 days)</p>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">DuckLake (Analytics) Retention</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        DuckLake holds the long-tail copy used for percentiles, group-by-endpoint, and time-bucketing.
        Columnar storage is cheap, so these can run a lot longer than the SQLite values above.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div>
          <%= form.label :ducklake_events_retention_days, "Keep Events", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :ducklake_events_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 365 days</p>
        </div>

        <div>
          <%= form.label :ducklake_transactions_retention_days, "Keep Transactions", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :ducklake_transactions_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 365 days</p>
        </div>

        <div>
          <%= form.label :ducklake_issues_retention_days, "Keep Issue Snapshots", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :ducklake_issues_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 730 days</p>
        </div>

        <div>
          <%= form.label :ducklake_spans_retention_days, "Keep Spans", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :ducklake_spans_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 30 days (high-volume detail)</p>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Noise Control</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        When an open issue's event rate over the last hour crosses the threshold below, Splat
        sends a spike alert (email + ntfy) — deduped to one per issue per hour. If
        <em>Auto-ignore</em> is also enabled, the issue is additionally flipped to ignored so
        it stops dominating the list. The same threshold drives the 🔥 burst badge on the
        issues list.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :auto_ignore_enabled, "Enable auto-ignore", class: "flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300" do %>
            <%= form.check_box :auto_ignore_enabled, class: "rounded border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-blue-600 focus:ring-blue-500" %>
            Auto-ignore bursting issues
          <% end %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">When off (default), spike alerts still fire but the issue stays open and tracked normally.</p>
        </div>

        <div>
          <%= form.label :auto_ignore_threshold, "Spike threshold", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :auto_ignore_threshold, min: 1, max: 1_000_000, class: "block w-32 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">events / hour</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 1,000 / hour.</p>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">ntfy Notifications</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        Push notifications via <a href="https://ntfy.sh" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener">ntfy</a> for new and reopened issues.
        Leave the topic URL blank to disable.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="md:col-span-2">
          <%= form.label :ntfy_url, "Topic URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.url_field :ntfy_url, placeholder: "https://ntfy.sh/my-splat-topic", class: "block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Full URL to your topic (e.g. <code>https://ntfy.sh/my-topic</code> or a self-hosted server).</p>
        </div>

        <div>
          <%= form.label :ntfy_token, "Access Token (optional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.password_field :ntfy_token, value: @setting.ntfy_token, autocomplete: "off", class: "block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Bearer token for protected topics. Sent as <code>Authorization: Bearer ...</code>.</p>
        </div>

        <div>
          <%= form.label :ntfy_priority, "Priority", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.select :ntfy_priority, NtfyNotifier::VALID_PRIORITIES.map { |p| [p, p] }, {}, class: "block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default priority (<code>min</code>, <code>low</code>, <code>default</code>, <code>high</code>, <code>max</code>).</p>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Current Status</h2>

      <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">SQLite (hot)</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
          <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">
            <%= number_with_delimiter(Event.count) %>
          </div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Total Events</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            <%= number_with_delimiter(Event.where.not(payload: nil).count) %> with payloads
          </div>
        </div>

        <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
          <div class="text-2xl font-bold text-green-600 dark:text-green-400">
            <%= number_with_delimiter(Transaction.count) %>
          </div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Total Transactions</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            <%= number_with_delimiter(Transaction.where.not(measurements: nil).count) %> with measurements
          </div>
        </div>
      </div>

      <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">DuckLake (analytics)</h3>
      <%
        ducklake_counts =
          begin
            {
              events:       DuckLake::Event.query("SELECT COUNT(*) AS n FROM #{DuckLake::Event.from_clause}").first["n"],
              transactions: DuckLake::Transaction.query("SELECT COUNT(*) AS n FROM #{DuckLake::Transaction.from_clause}").first["n"],
              spans:        DuckLake::Span.query("SELECT COUNT(*) AS n FROM #{DuckLake::Span.from_clause}").first["n"]
            }
          rescue => e
            { error: "#{e.class}: #{e.message}" }
          end
      %>
      <% if ducklake_counts[:error] %>
        <div class="p-4 bg-red-50 dark:bg-red-900/30 rounded text-sm text-red-700 dark:text-red-300">
          DuckLake unavailable: <%= ducklake_counts[:error] %>
        </div>
      <% else %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
            <div class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= number_with_delimiter(ducklake_counts[:events]) %></div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Events</div>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
            <div class="text-2xl font-bold text-green-600 dark:text-green-400"><%= number_with_delimiter(ducklake_counts[:transactions]) %></div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Transactions</div>
          </div>
          <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
            <div class="text-2xl font-bold text-amber-600 dark:text-amber-400"><%= number_with_delimiter(ducklake_counts[:spans]) %></div>
            <div class="text-sm text-gray-600 dark:text-gray-400">Spans</div>
          </div>
        </div>
      <% end %>

      <div class="mt-4 p-4 bg-blue-50 dark:bg-blue-900/30 rounded">
        <div class="text-sm text-blue-800 dark:text-blue-300">
          <strong>SQLite cleanup</strong> runs daily at 2am via <code>DataRetentionJob</code>.
          <strong>Parquet cleanup</strong> runs daily via <code>ParquetLake::CompactionJob</code> and <code>ParquetLake::RetentionJob</code> (see <code>config/schedule.yml</code>).
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <%= form.submit "Update Settings", class: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline" %>
    </div>
  <% end %>
</div>
