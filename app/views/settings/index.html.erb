<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-3xl text-gray-900 dark:text-gray-100">Settings</h1>
    <%= link_to "← Back to Projects", projects_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-2">
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm text-gray-500 dark:text-gray-400">SQLite total (all 3 DBs)</div>
      <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100">
        <%= @storage ? number_to_human_size(@storage[:total]) : "—" %>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <div class="text-sm text-gray-500 dark:text-gray-400">Histogram rows</div>
      <div class="mt-1 text-2xl font-semibold text-gray-900 dark:text-gray-100">
        <%= number_with_delimiter(TransactionsSpansRecord.connection.select_value("SELECT COUNT(*) FROM transaction_histograms").to_i) %>
      </div>
    </div>
  </div>

  <p class="text-xs text-gray-500 dark:text-gray-400 mb-6">
    <% if @storage %>
      Storage sizes collected <%= time_ago_in_words(@storage[:collected_at]) %> ago
      (<%= @storage[:collected_at].localtime.strftime("%Y-%m-%d %H:%M") %>) —
      refreshed every 15&nbsp;min by <code>Maintenance::StorageStatsJob</code>.
    <% else %>
      Storage sizes are being calculated in the background — reload in a moment.
    <% end %>
  </p>

  <% if @storage.nil? %>
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg border border-gray-200 dark:border-gray-800 mb-4 px-6 py-8 text-center text-gray-500 dark:text-gray-400">
      Calculating per-table sizes…
    </div>
  <% end %>

  <% (@storage&.fetch(:groups) || []).each do |group| %>
    <details class="bg-white dark:bg-gray-900 shadow rounded-lg border border-gray-200 dark:border-gray-800 mb-4 overflow-hidden group">
      <summary class="px-6 py-4 cursor-pointer flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-800/50 list-none">
        <div>
          <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100"><%= group[:name] %></h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><code><%= group[:base] %></code> — per-page bytes from <code>dbstat</code>.</p>
        </div>
        <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 transition-transform group-open:rotate-90 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </summary>
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800 border-t border-gray-200 dark:border-gray-800">
        <thead class="bg-gray-50 dark:bg-gray-800/50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Table</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Rows</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Table size</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Indexes</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
          <% group[:tables].each do |t| %>
            <tr>
              <td class="px-6 py-3 text-sm font-mono text-gray-900 dark:text-gray-100"><%= t[:name] %></td>
              <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_with_delimiter(t[:row_estimate]) %></td>
              <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_to_human_size(t[:table_bytes]) %></td>
              <td class="px-6 py-3 text-sm text-right text-gray-700 dark:text-gray-300"><%= number_to_human_size(t[:index_bytes]) %></td>
              <td class="px-6 py-3 text-sm text-right font-medium text-gray-900 dark:text-gray-100"><%= number_to_human_size(t[:total_bytes]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </details>
  <% end %>

  <h2 class="font-bold text-2xl text-gray-900 dark:text-gray-100 mb-4 mt-8">Data Retention</h2>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900/40 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-300 px-4 py-3 rounded mb-6">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="bg-red-100 dark:bg-red-900/40 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-6">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with(model: @setting, url: settings_path, method: :put, class: "space-y-6") do |form| %>
    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Raw row retention</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        How long to keep the raw events / transactions / spans before the daily retention job deletes them.
        Aggregate performance history (latency distribution in <code>transaction_histograms</code> plus
        per-hour counts/averages/N+1/errors in <code>transaction_hourly_stats</code>) is retained separately
        below, so endpoint stats and the latency/volume charts keep working long after the raw rows age out.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= form.label :events_data_retention_days, "Keep events", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :events_data_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 30 days</p>
        </div>

        <div>
          <%= form.label :transactions_data_retention_days, "Keep transactions", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :transactions_data_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 90 days</p>
        </div>

        <div>
          <%= form.label :spans_data_retention_days, "Keep spans", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :spans_data_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 30 days (waterfall is high-volume)</p>
        </div>

        <div>
          <%= form.label :histograms_retention_days, "Keep aggregates", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <div class="flex items-center space-x-2">
            <%= form.number_field :histograms_retention_days, min: 1, max: 3650, class: "block w-24 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            <span class="text-gray-600 dark:text-gray-400">days</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Histograms + hourly stats. Default: 540 days — they're tiny.</p>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Counts</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
          <div class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= number_with_delimiter(Issue.count) %></div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Issues</div>
        </div>
        <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
          <div class="text-2xl font-bold text-blue-600 dark:text-blue-400"><%= number_with_delimiter(Event.count) %></div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Events</div>
        </div>
        <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
          <div class="text-2xl font-bold text-green-600 dark:text-green-400"><%= number_with_delimiter(Transaction.count) %></div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Transactions</div>
        </div>
        <div class="text-center p-4 bg-gray-50 dark:bg-gray-800 rounded">
          <div class="text-2xl font-bold text-amber-600 dark:text-amber-400"><%= number_with_delimiter(Span.count) %></div>
          <div class="text-sm text-gray-600 dark:text-gray-400">Spans</div>
        </div>
      </div>

      <div class="mt-4 p-4 bg-blue-50 dark:bg-blue-900/30 rounded">
        <div class="text-sm text-blue-800 dark:text-blue-300">
          Retention runs daily at 02:00 via <code>Maintenance::RetentionJob</code>; histogram rollup runs hourly at <code>:05</code>.
          See <code>config/schedule.yml</code>.
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-semibold mb-4 text-gray-800 dark:text-gray-100">Alerting</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        When an open issue emits at least the burst threshold of events in an hour, Splat
        sends a spike alert (email + ntfy) — deduped to one per issue per hour. The same
        threshold drives the 🔥 burst badge on the issues list.
      </p>

      <div class="mb-6">
        <%= form.label :burst_threshold, "Burst threshold", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <div class="flex items-center space-x-2">
          <%= form.number_field :burst_threshold, min: 1, max: 1_000_000, class: "block w-32 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <span class="text-gray-600 dark:text-gray-400">events / hour</span>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Default: 1,000 events/hour.</p>
      </div>

      <h3 class="text-base font-semibold mb-2 text-gray-800 dark:text-gray-100">ntfy notifications</h3>
      <p class="text-gray-600 dark:text-gray-400 mb-4 text-sm">
        Push notifications via <a href="https://ntfy.sh" class="text-blue-600 dark:text-blue-400 underline" target="_blank" rel="noopener">ntfy</a>
        for new issues, reopened issues, and bursts. Leave the topic URL blank to disable.
      </p>

      <div class="space-y-4">
        <div>
          <%= form.label :ntfy_url, "Topic URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.url_field :ntfy_url, placeholder: "https://ntfy.sh/my-splat-topic", class: "block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Full URL to your topic (e.g. <code>https://ntfy.sh/my-topic</code> or a self-hosted server).</p>
        </div>

        <div>
          <%= form.label :ntfy_token, "Access token (optional)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.password_field :ntfy_token, value: @setting.ntfy_token, autocomplete: "off", class: "block w-full rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Bearer token for an access-protected topic.</p>
        </div>

        <div>
          <%= form.label :ntfy_priority, "Priority", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.select :ntfy_priority, NtfyNotifier::VALID_PRIORITIES.map { |p| [p, p] }, {}, class: "block w-48 rounded-md border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <%= form.submit "Update Settings", class: "bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline" %>
    </div>
  <% end %>

  <h2 class="font-bold text-2xl text-gray-900 dark:text-gray-100 mb-4 mt-8">About</h2>

  <div class="bg-white dark:bg-gray-900 shadow rounded-lg p-6 border border-gray-200 dark:border-gray-800">
    <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <dt class="text-sm text-gray-500 dark:text-gray-400">Splat</dt>
        <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= Splat::VERSION %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500 dark:text-gray-400">Rails</dt>
        <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= Rails.version %></dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500 dark:text-gray-400">Ruby</dt>
        <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= RUBY_VERSION %></dd>
      </div>
    </dl>
  </div>
</div>
